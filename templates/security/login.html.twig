{% extends 'base.html.twig' %}

{% block title %}Log in!{% endblock %}

{% block body %}
<div class="flex min-h-full items-center justify-center px-6 py-12">
    <div class="w-full max-w-sm rounded-xl border border-gray-200 bg-white p-8 shadow-sm">

        <form method="post" class="space-y-5">

            {% if error %}
                <div class="rounded-lg border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700">
                    {{ error.messageKey|trans(error.messageData, 'security') }}
                </div>
            {% endif %}

            {% if app.user %}
                <div class="rounded-lg border border-gray-200 bg-gray-50 px-4 py-3 text-sm text-gray-600">
                    You are logged in as {{ app.user.userIdentifier }},
                    <a href="{{ path('app_logout') }}" class="font-medium text-indigo-600 hover:text-indigo-500">
                        Logout
                    </a>
                </div>
            {% endif %}

            <h1 class="text-xl font-bold tracking-tight text-gray-900">
                Please sign in
            </h1>

            <div class="flex flex-col">
                <label for="username" class="block text-sm font-medium text-gray-700 mb-1">
                    Email
                </label>
                <input type="email" value="{{ last_username }}" name="_username" id="username"
                       autocomplete="email" required autofocus
                       class="block w-full p-2 rounded-lg border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm">
            </div>

            <div class="flex flex-col">
                <label for="password" class="block text-sm font-medium text-gray-700 mb-1">
                    Password
                </label>
                <input type="password" name="_password" id="password"
                       autocomplete="current-password" required
                       class="block w-full p-2 rounded-lg border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm">
            </div>

            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

            {#
                Uncomment this section and add a remember_me option below your firewall to activate remember me functionality.
                See https://symfony.com/doc/current/security/remember_me.html
                <div class="flex items-center gap-2">
                    <input type="checkbox" name="_remember_me" id="remember_me"
                           class="h-4 w-4 rounded border-gray-300 text-indigo-600 focus:ring-indigo-500">
                    <label for="remember_me" class="text-sm text-gray-700">Remember me</label>
                </div>
            #}

            <button type="submit"
                    class="w-full inline-flex justify-center rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white hover:bg-indigo-500">
                Sign in
            </button>

        </form>
    </div>
</div>
{% endblock %}