{% extends 'base.html.twig' %}

{% block body %}
<div class="mx-auto max-w-2xl px-6 py-12">
    <div class="rounded-xl border border-gray-200 bg-white p-8 shadow-sm">
        <h1 class="mb-6 text-xl font-bold tracking-tight text-gray-900">
            Créer des pointages multiples
        </h1>

        {# Capturer le prototype rendu dans une variable #}
        {% set prototype_html %}
            <div class="collaborator-row flex gap-2 items-end p-3 bg-gray-50 rounded-lg">
                <div class="flex-1">
                    {{ form_widget(form.collaborators.vars.prototype.user, {
                        attr: {class: 'block w-full rounded-lg border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm p-2'}
                    }) }}
                </div>
                <div class="w-24">
                    {{ form_widget(form.collaborators.vars.prototype.duration, {
                        attr: {class: 'block w-full rounded-lg border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm p-2'}
                    }) }}
                </div>
                <button type="button" class="btn-remove-collaborator px-3 py-2 bg-red-500 hover:bg-red-600 text-white rounded-lg text-sm font-medium transition">
                    ✕
                </button>
            </div>
        {% endset %}

        {{ form_start(form, {attr: {class: 'space-y-5'}}) }}

            {{ form_row(form.date) }}
            {{ form_row(form.project) }}

            <fieldset class="space-y-4">
                <legend class="block text-sm font-medium text-gray-700 mb-2">
                    {{form_label(form.collaborators)}}
                </legend>

                <div id="collaborators-container" 
                     data-prototype="{{ prototype_html|e('html_attr') }}"
                     class="space-y-3">
                    {% for collaborator in form.collaborators %}
                        {% if collaborator.user.vars.errors|length > 0 or collaborator.duration.vars.errors|length > 0 %}
                            <div class="w-full mb-3 p-3 bg-red-50 border border-red-200 rounded-lg text-red-700 text-sm">
                                {% if collaborator.user.vars.errors|length > 0 %}
                                    <strong>Collaborateur :</strong>
                                    {{ form_errors(collaborator.user) }}
                                {% endif %}
                                {% if collaborator.duration.vars.errors|length > 0 %}
                                    <strong>Durée :</strong>
                                    {{ form_errors(collaborator.duration) }}
                                {% endif %}
                            </div>
                        {% endif %}

                        <div class="collaborator-row flex gap-2 items-end p-3 bg-gray-50 rounded-lg">
                            <div class="flex-1">
                                {{ form_widget(collaborator.user, {
                                    attr: {class: 'block w-full rounded-lg border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm p-2'}
                                }) }}
                            </div>
                            
                            <div class="w-24">
                                {{ form_widget(collaborator.duration, {
                                    attr: {class: 'block w-full rounded-lg border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm p-2'}
                                }) }}
                            </div>
                            
                            <button type="button" class="btn-remove-collaborator px-3 py-2 bg-red-500 hover:bg-red-600 text-white rounded-lg text-sm font-medium transition">
                                ✕
                            </button>
                        </div>
                        {% else %}
                            <div id="no-collaborators" class="text-center py-4 text-gray-500">
                                Aucun collaborateur ajouté pour le moment
                            </div>
                    {% endfor %}
                </div>

                    <button type="button" id="btn-add-collaborator" class="mt-3 px-4 py-2 bg-green-500 hover:bg-green-600 text-white rounded-lg text-sm font-medium transition">
                        + Ajouter un collaborateur
                    </button>
            </fieldset>

            {{ form_widget(form._token) }}
            {{ form_row(form.submit) }}

        {{ form_end(form, {render_rest: false}) }}
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const container = document.getElementById('collaborators-container');
    const prototype = container.dataset.prototype;
    let collaboratorIndex = container.querySelectorAll('.collaborator-row').length;

    // Ajouter un nouveau collaborateur
    document.getElementById('btn-add-collaborator')?.addEventListener('click', function(e) {
        e.preventDefault();

        // Masquer le message "aucun collaborateur"
        const noCollaborators = document.getElementById('no-collaborators');
        if (noCollaborators) noCollaborators.remove();

        // Créer une nouvelle ligne
        const newForm = prototype.replace(/__name__/g, collaboratorIndex);
        
        const wrapper = document.createElement('div');
        wrapper.innerHTML = newForm;

        container.appendChild(wrapper.firstElementChild);

        // Ajouter les event listeners
        attachRemoveListener(wrapper.querySelector('.btn-remove-collaborator'));

        collaboratorIndex++;
    });

    // Supprimer un collaborateur
    function attachRemoveListener(button) {
        button?.addEventListener('click', function(e) {
            e.preventDefault();
            const row = this.closest('.collaborator-row');
            row.remove();

            // Afficher le message si plus aucun collaborateur
            if (container.querySelectorAll('.collaborator-row').length === 0) {
                const noCollaborators = document.createElement('div');
                noCollaborators.id = 'no-collaborators';
                noCollaborators.className = 'text-center py-4 text-gray-500';
                noCollaborators.textContent = 'Aucun collaborateur ajouté pour le moment';
                container.appendChild(noCollaborators);
            }
        });
    }

    // Attacher les listeners aux boutons existants
    document.querySelectorAll('.btn-remove-collaborator').forEach(attachRemoveListener);
});
</script>
{% endblock %}