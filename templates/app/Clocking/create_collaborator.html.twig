{% extends 'base.html.twig' %}

{% block body %}
<div class="mx-auto max-w-2xl px-6 py-12">
    <div class="rounded-xl border border-gray-200 bg-white p-8 shadow-sm">
        <h1 class="mb-6 text-xl font-bold tracking-tight text-gray-900">
            Mon pointage
        </h1>

        {# Capturer le prototype rendu dans une variable #}
        {% set prototype_html %}
            <div class="project-row flex gap-2 items-end p-3 bg-gray-50 rounded-lg">
                <div class="flex-1">
                    {{ form_widget(form.projects.vars.prototype.project, {
                        attr: {class: 'block w-full rounded-lg border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm p-2'}
                    }) }}
                </div>
                <div class="w-24">
                    {{ form_widget(form.projects.vars.prototype.duration, {
                        attr: {class: 'block w-full rounded-lg border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm p-2'}
                    }) }}
                </div>
                <button type="button" class="btn-remove-project px-3 py-2 bg-red-500 hover:bg-red-600 text-white rounded-lg text-sm font-medium transition">
                    ✕
                </button>
            </div>
        {% endset %}

        {{ form_start(form, {attr: {class: 'space-y-5'}}) }}

            {{ form_row(form.date) }}

            <fieldset class="space-y-4">
                <legend class="block text-sm font-medium text-gray-700 mb-2">
                    Chantiers et durées
                </legend>

                <div id="projects-container" 
                     data-prototype="{{ prototype_html|e('html_attr') }}"
                     class="space-y-3">
                    {% for project in form.projects %}
                        {% if project.project.vars.errors|length > 0 or project.duration.vars.errors|length > 0 %}
                            <div class="w-full mb-3 p-3 bg-red-50 border border-red-200 rounded-lg text-red-700 text-sm">
                                {% if project.project.vars.errors|length > 0 %}
                                    <strong>Chantier :</strong>
                                    {{ form_errors(project.project) }}
                                {% endif %}
                                {% if project.duration.vars.errors|length > 0 %}
                                    <strong>Durée :</strong>
                                    {{ form_errors(project.duration) }}
                                {% endif %}
                            </div>
                        {% endif %}

                        <div class="project-row flex gap-2 items-end p-3 bg-gray-50 rounded-lg">
                            <div class="flex-1">
                                {{ form_widget(project.project, {
                                    attr: {class: 'block w-full rounded-lg border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm p-2'}
                                }) }}
                            </div>
                            <div class="w-24">
                                {{ form_widget(project.duration, {
                                    attr: {class: 'block w-full rounded-lg border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm p-2'}
                                }) }}
                            </div>
                            <button type="button" class="btn-remove-project px-3 py-2 bg-red-500 hover:bg-red-600 text-white rounded-lg text-sm font-medium transition">
                                ✕
                            </button>
                        </div>
                    {% else %}
                        <div id="no-projects" class="text-center py-4 text-gray-500">
                            Aucun chantier ajouté pour le moment
                        </div>
                    {% endfor %}
                </div>

                <button type="button" id="btn-add-project" class="mt-3 px-4 py-2 bg-green-500 hover:bg-green-600 text-white rounded-lg text-sm font-medium transition">
                    + Ajouter un chantier
                </button>
            </fieldset>

            {% if form.projects.vars.errors|length > 0 %}
                <div class="p-3 bg-red-50 border border-red-200 rounded-lg text-red-700 text-sm">
                    {{ form_errors(form.projects) }}
                </div>
            {% endif %}

            {{ form_widget(form._token) }}
            {{ form_row(form.submit) }}

        {{ form_end(form, {render_rest: false}) }}
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const container = document.getElementById('projects-container');
    const prototype = container.dataset.prototype;
    let projectIndex = container.querySelectorAll('.project-row').length;

    // Ajouter un nouveau projet
    document.getElementById('btn-add-project')?.addEventListener('click', function(e) {
        e.preventDefault();

        // Masquer le message "aucun projet"
        const noProjects = document.getElementById('no-projects');
        if (noProjects) noProjects.remove();

        // Créer une nouvelle ligne
        const newForm = prototype.replace(/__name__/g, projectIndex);
        
        const wrapper = document.createElement('div');
        wrapper.innerHTML = newForm;

        container.appendChild(wrapper.firstElementChild);

        // Ajouter les event listeners
        attachRemoveListener(wrapper.querySelector('.btn-remove-project'));

        projectIndex++;
    });

    // Supprimer un projet
    function attachRemoveListener(button) {
        button?.addEventListener('click', function(e) {
            e.preventDefault();
            const row = this.closest('.project-row');
            row.remove();

            // Afficher le message si plus aucun projet
            if (container.querySelectorAll('.project-row').length === 0) {
                const noProjects = document.createElement('div');
                noProjects.id = 'no-projects';
                noProjects.className = 'text-center py-4 text-gray-500';
                noProjects.textContent = 'Aucun chantier ajouté pour le moment';
                container.appendChild(noProjects);
            }
        });
    }

    // Attacher les listeners aux boutons existants
    document.querySelectorAll('.btn-remove-project').forEach(attachRemoveListener);
});
</script>
{% endblock %}